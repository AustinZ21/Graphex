# CGA-Relay config example.
# Store environment variable names here, never secret values.

AGENT_ID=dev-machine-01
API_BASE_URL=http://127.0.0.1:18001
CONTROL_API_BASE_URL=http://127.0.0.1:18001
API_KEY_ENV=CGA_API_KEY
ACCOUNT_EMAIL=dev@example.com
ACCOUNT_TOKEN_ENV=CGA_DEVELOPER_TOKEN
PROJECT_ID=replace-with-stable-project-id
PROJECT_ROOT=C:\\Repos\\ExampleProject
STATE_DIR=%USERPROFILE%\\.cga\\state
LOG_DIR=%USERPROFILE%\\.cga\\logs
INCLUDE_GLOBS=
EXCLUDE_GLOBS=.git/**,node_modules/**,.venv/**,__pycache__/**,dist/**,build/**,target/**,<agent-state>/**
MAX_FILE_BYTES=1048576
