%% Layout target: landscape Letter paper, compact two-lane diagram.
flowchart TB
    subgraph Build["Build the AST"]
        direction LR
        Code["Source code or model output"]
        Tokens["Tokens"]
        Parser["Parser"]
        AST["Abstract Syntax Tree"]
        Code --> Tokens --> Parser --> AST
    end

    subgraph Shape["What the AST contains"]
        direction LR
        Root["File root"]
        Imports["Imports"]
        Funcs["Functions"]
        Calls["Calls and variables"]
        Root --> Imports
        Root --> Funcs
        Funcs --> Calls
    end

    subgraph Use["Use the AST"]
        direction LR
        Symbols["Symbols and scopes"]
        Semantics["Reference and API checks"]
        Edges["ContextGraph code edges"]
        Gate{"Valid?"}
        Transform["Safe transform"]
        Done["Verified code change"]
        Symbols --> Semantics --> Edges --> Gate
        Gate -->|yes| Transform --> Done
    end

    AST --> Root
    AST --> Symbols

    Gate -->|no| Error["Exact error location"]
    Error --> Repair["Repair subtree"]
    Repair --> Parser

    classDef source fill:#ecfeff,stroke:#0891b2,color:#0f172a
    classDef ast fill:#eef2ff,stroke:#4f46e5,color:#111827
    classDef check fill:#f0fdf4,stroke:#16a34a,color:#111827
    classDef error fill:#fef2f2,stroke:#dc2626,color:#111827
    classDef context fill:#fff7ed,stroke:#ea580c,color:#111827

    class Code,Tokens,Parser source
    class AST,Root,Imports,Funcs,Calls ast
    class Symbols,Semantics,Gate,Transform,Done check
    class Error,Repair error
    class Edges context