# CGA (ContextGraphAdmin) — Environment Variables Example
# Copy to .env and fill in values before running locally.
# docker compose --profile dev up  (starts FalkorDB:16379 + Redis:6380)

# ── Docker / release helpers ─────────────────────────────────────────────────
# Version tag used by docker-compose.release.yml when pulling GHCR images.
CGA_VERSION=latest

# Local path mounted into /repos for dev indexing examples.
CGA_REPOS_MOUNT=.

# Docker Desktop one-click launcher port overrides (optional).
# Defaults are 18001 for the Admin API, 16381 for FalkorDB, and 13001 for FalkorDB Browser.
# CGA_DESKTOP_API_PORT=18001
# CGA_DESKTOP_FALKORDB_PORT=16381
# CGA_DESKTOP_BROWSER_PORT=13001

# ── FalkorDB ──────────────────────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=16379
# FalkorDB Browser login URL (falkor:// protocol, internal container port)
FALKORDB_URL=falkor://localhost:6379
# From host machine (Redis protocol via mapped port)
FALKORDB_URL_HOST=redis://localhost:16379

# ── Redis (queue / cache) ─────────────────────────────────────────────────────
QUEUE_REDIS_URL=redis://localhost:6380/1
CACHE_REDIS_URL=redis://localhost:6380/2

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-at-least-32-chars!!!!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional encryption key for stored OAuth token caches. If omitted, CGA derives
# a local key from JWT_SECRET_KEY; set this before production-like use.
CGA_OAUTH_TOKEN_KEY=

# Microsoft / Azure DevOps connected-account lookup for the Report tab.
# CGA defaults to a Microsoft public client for local device-code sign-in;
# override this with a CGA-owned public client id when distributing broadly.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_TENANT=organizations
MICROSOFT_OAUTH_SCOPE=499b84ac-1321-427f-aa17-267ca6975798/.default offline_access openid profile

# ── MCP legacy token (for agentrouter compat) ────────────────────────────────
MCP_ACCESS_TOKEN=

# ── API ───────────────────────────────────────────────────────────────────────
PYTHONPATH=src
