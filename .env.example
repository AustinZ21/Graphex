# ContextGraph — Environment Variables Example
# Copy to .env and fill in values before running locally.
# docker compose --profile dev up  (starts FalkorDB:16379 + Redis:6380)

# ── FalkorDB ──────────────────────────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=16379
# Convenience URL for tools that accept a redis:// URI (FalkorDB speaks Redis protocol)
FALKORDB_URL=redis://localhost:16379

# ── Redis (queue / cache) ─────────────────────────────────────────────────────
QUEUE_REDIS_URL=redis://localhost:6380/1
CACHE_REDIS_URL=redis://localhost:6380/2

# ── Auth / SQLite ─────────────────────────────────────────────────────────────
AUTH_DB_PATH=/app/data/auth.db
JWT_SECRET_KEY=change-me-at-least-32-chars!!!!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── MCP legacy token (for agentrouter compat) ────────────────────────────────
MCP_ACCESS_TOKEN=

# ── API ───────────────────────────────────────────────────────────────────────
PYTHONPATH=src
