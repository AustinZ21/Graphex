# CGA Desktop bundle settings
# Copy this file to .env in the same folder if you want fixed settings.

# Folder mounted into /repos for indexing.
# Default ../../ points to the repository root when using this bundle in-place.
# If you copy this folder elsewhere, set it to the code folder you want CGA to read.
CGA_REPOS_MOUNT=../../

# Desktop host ports.
CGA_DESKTOP_API_PORT=18001
CGA_DESKTOP_FALKORDB_PORT=16381
CGA_DESKTOP_BROWSER_PORT=13001

# Local credentials.
JWT_SECRET_KEY=change-me-at-least-32-chars!!!!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional legacy MCP token.
MCP_ACCESS_TOKEN=